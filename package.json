{
  "name": "helldivers-after-action-report",
  "version": "1.0.0",
  "description": "Helldivers 2 after-action report Discord bot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts",
